{
  "name": "Transcribely",
  "version": "2.3.0",
  "description": "Electron app for Bedrock models and media transcription",
  "main": "main.js",
  "author": "Transcribely Team",
  "homepage": "https://transcribely.app",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "publish": "./build-scripts/publish.sh all",
    "publish:mac": "./build-scripts/publish.sh mac",
    "publish:win": "./build-scripts/publish.sh win",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:bedrock": "jest tests/main/bedrock-llm.test.js --verbose --testMatch='**/bedrock-llm.test.js'",
    "test:bedrock-quick": "jest tests/main/bedrock-llm.test.js --verbose --testMatch='**/bedrock-llm.test.js' --testNamePattern='Nova Pro.*Summarize Text'",
    "test:code-interpreter": "node tests/diag-code-interpreter.js",
    "test:memory": "node tests/diag-memory.js",
    "test:validate": "node tests/main/validate-setup.js"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-bedrock": "^3.775.0",
    "@aws-sdk/client-bedrock-agent": "^3.808.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.0.0",
    "@aws-sdk/client-bedrock-agentcore": "^3.1007.0",
    "@aws-sdk/client-bedrock-agentcore-control": "^3.1008.0",
    "@aws-sdk/client-bedrock-runtime": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-sagemaker-runtime": "^3.1008.0",
    "@aws-sdk/client-sts": "^3.0.0",
    "@aws-sdk/client-transcribe": "^3.0.0",
    "@aws-sdk/credential-providers": "^3.1007.0",
    "@aws-sdk/lib-storage": "^3.0.0",
    "@smithy/signature-v4": "^5.3.12",
    "bootstrap": "^5.3.0",
    "bootstrap-icons": "^1.11.1",
    "electron-updater": "^6.8.3",
    "marked": "^17.0.4",
    "playwright-core": "^1.58.2",
    "toastify-js": "^1.12.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4"
  },
  "jest": {
    "testEnvironment": "jest-environment-jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "!**/tests/main/bedrock-llm.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testEnvironmentOptions": {
      "url": "http://localhost"
    },
    "testTimeout": 30000
  },
  "build": {
    "appId": "com.transcribely.app",
    "productName": "Transcribely",
    "afterPack": "./build-scripts/afterPack.js",
    "directories": {
      "output": "dist/temp"
    },
    "files": [
      "**/*",
      "!tests/**/*",
      "!coverage/**/*",
      "!dist/**/*"
    ],
    "artifactName": "${productName}-${version}-${platform}-${arch}.${ext}",
    "mac": {
      "icon": "src/assets/app.icns",
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "zip", "arch": ["universal"] }
      ],
      "artifactName": "${productName}-${version}-universal.${ext}",
      "darkModeSupport": true,
      "notarize": false
    },
    "win": {
      "icon": "src/assets/favicon-win.ico",
      "target": "nsis",
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "linux": {
      "icon": "src/assets/favicon_512x512.png",
      "category": "AudioVideo",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "s3",
      "bucket": "transcribely-releases",
      "region": "us-east-1",
      "path": "/releases"
    },
    "mac": {
      "icon": "src/assets/app.icns",
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "zip", "arch": ["universal"] }
      ],
      "artifactName": "${productName}-${version}-universal.${ext}",
      "darkModeSupport": true,
      "notarize": false
    }
  }
}
