{
  "name": "Transcribely",
  "version": "1.0.0",
  "description": "Electron app for Bedrock models and media transcription",
  "main": "main.js",
  "author": "Transcribely Team",
  "homepage": "https://transcribely.app",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.775.0",
    "@aws-sdk/client-bedrock-agent": "^3.808.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.0.0",
    "@aws-sdk/client-bedrock-runtime": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-sts": "^3.0.0",
    "@aws-sdk/client-transcribe": "^3.0.0",
    "@aws-sdk/lib-storage": "^3.0.0",
    "bootstrap": "^5.3.0",
    "bootstrap-icons": "^1.11.1",
    "toastify-js": "^1.12.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "electron-builder": "^24.0.0",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "jsdom": "^26.1.0",
    "electron": "^25.0.0"
  },
  "jest": {
    "testEnvironment": "jest-environment-jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testEnvironmentOptions": {
      "url": "http://localhost"
    }
  },
  "build": {
    "appId": "com.transcribely.app",
    "productName": "Transcribely",
    "directories": {
      "output": "dist/temp"
    },
    "files": [
      "**/*",
      "!tests/**/*",
      "!coverage/**/*",
      "!dist/**/*"
    ],
    "artifactName": "${productName}-${version}-${platform}-${arch}.${ext}",
    "mac": {
      "icon": "src/assets/app.icns",
      "category": "public.app-category.productivity",
      "target": ["dmg"],
      "artifactName": "${productName}-${version}-universal.${ext}",
      "darkModeSupport": true
    },
    "win": {
      "icon": "src/assets/favicon-win.ico",
      "target": "nsis",
      "publisherName": "Transcribely",
      "artifactName": "${productName}-Setup-${arch}.${ext}"
    },
    "linux": {
      "icon": "src/assets/favicon_512x512.png",
      "category": "AudioVideo",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}